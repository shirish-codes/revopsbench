{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Plus Jakarta Sans', sans-serif",
          "name": "Plus Jakarta Sans",
          "slug": "plus-jakarta-sans"
        },
        {
          "fontFamily": "'Inter', sans-serif",
          "name": "Inter",
          "slug": "inter"
        }
      ],
      "fontSizes": [
        { "slug": "xs",   "size": "0.75rem",  "name": "XS"   },
        { "slug": "sm",   "size": "0.875rem", "name": "Small" },
        { "slug": "base", "size": "1rem",     "name": "Base"  },
        { "slug": "lg",   "size": "1.25rem",  "name": "Large" },
        { "slug": "xl",   "size": "1.5rem",   "name": "XL"    },
        { "slug": "2xl",  "size": "2rem",     "name": "2XL"   },
        { "slug": "3xl",  "size": "2.75rem",  "name": "3XL"   },
        { "slug": "4xl",  "size": "3.75rem",  "name": "4XL"   },
        { "slug": "5xl",  "size": "5rem",     "name": "5XL"   }
      ],
      "fluid": true,
      "customFontSize": true
    },
    "color": {
      "palette": [
        { "color": "#07070E", "name": "Base Black",     "slug": "base-black"    },
        { "color": "#0D0D1A", "name": "Elevated Black", "slug": "elevated-black" },
        { "color": "#00E6A0", "name": "Teal 500",       "slug": "teal-500"      },
        { "color": "#00CFFF", "name": "Cyan 400",       "slug": "cyan-400"      },
        { "color": "#00B894", "name": "Teal 600",       "slug": "teal-600"      },
        { "color": "#3B82F6", "name": "Blue 500",       "slug": "blue-500"      },
        { "color": "#60A5FA", "name": "Blue 400",       "slug": "blue-400"      },
        { "color": "#FFFFFF", "name": "White",           "slug": "white"         },
        { "color": "rgba(255,255,255,0.65)", "name": "Text Secondary", "slug": "text-secondary" },
        { "color": "rgba(255,255,255,0.38)", "name": "Text Muted",     "slug": "text-muted"     }
      ],
      "custom": true,
      "customDuotone": false,
      "customGradient": true,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false
    },
    "spacing": {
      "units": ["px", "rem", "%", "vw", "vh"]
    },
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },
    "border": {
      "radius": true,
      "style": true,
      "width": true
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.7"
    },
    "color": {
      "background": "#07070E",
      "text": "#FFFFFF"
    },
    "spacing": {
      "blockGap": "0"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--plus-jakarta-sans)",
          "fontWeight": "700",
          "lineHeight": "1.12"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--teal-500)"
        }
      }
    }
  },
  "customTemplates": [
    { "name": "front-page",     "title": "Front Page",    "postTypes": ["page"] },
    { "name": "page-thank-you", "title": "Thank You Page","postTypes": ["page"] },
    { "name": "page-hire",      "title": "Hire Page",     "postTypes": ["page"] }
  ],
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
